FROM maven:3.9-eclipse-temurin-17-alpine AS build
WORKDIR /app
COPY backend/pom.xml ./
RUN timeout 90 mvn -q -DskipTests dependency:go-offline || true
COPY backend/ ./
RUN mkdir -p src/main/resources && \
    if [ -f application.yml ]; then cp application.yml src/main/resources/application.yml; fi && \
    if [ -f resources/application.yml ]; then cp resources/application.yml src/main/resources/application.yml; fi
RUN mkdir -p src/main/java/com/example/book && cp 'BookApplication.java' 'src/main/java/com/example/book/BookApplication.java' && \
    mkdir -p src/main/java/com/example/book/controller && cp 'controller/BookController.java' 'src/main/java/com/example/book/controller/BookController.java' && \
    mkdir -p src/main/java/com/example/book/controller && cp 'controller/HealthController.java' 'src/main/java/com/example/book/controller/HealthController.java' && \
    mkdir -p src/main/java/com/example/book/entity && cp 'entity/Book.java' 'src/main/java/com/example/book/entity/Book.java' && \
    mkdir -p src/main/java/com/example/book/repository && cp 'repository/BookRepository.java' 'src/main/java/com/example/book/repository/BookRepository.java'

RUN rm -rf /root/.m2/repository/commons-io/commons-io/2.6 && \
    (mvn -q -DskipTests -Dstart-class=com.example.book.BookApplication package -Dmaven.wagon.http.retryHandler.count=3 || mvn -q -DskipTests -U -Dstart-class=com.example.book.BookApplication package -Dmaven.wagon.http.retryHandler.count=3)
FROM eclipse-temurin:17-jre-alpine
WORKDIR /app
COPY --from=build /app/target/*.jar app.jar
ENV SERVER_PORT=8080
EXPOSE 8080
CMD ["java", "-jar", "app.jar"]
